# ============================================================
# V-Guard AI Backend — Environment Variables
# Set di: Vercel Dashboard > Project > Settings > Environment Variables
# ============================================================

# Database MySQL
DB_HOST=your_mysql_host
DB_PORT=3306
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=vguard_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=production

# Frontend URL (untuk CORS)
FRONTEND_URL=https://vguard-dashboard.vercel.app

# WhatsApp (jika digunakan)
# WA_SESSION_PATH=./data/sessions
